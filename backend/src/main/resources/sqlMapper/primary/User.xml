<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="backend.user.repository.UserRepository">

    <!-- selectUsers --> 

    <select id="selectUsers" resultType="backend.user.model.UserResponseVO">
        SELECT id
             , email
             , password
             , status
        FROM User U
        WHERE U.id=#{id}


    </select>
</mapper>